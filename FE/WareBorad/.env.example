# Optional: set this if you want the frontend to call the backend directly (no Vite proxy).
# Example: VITE_API_BASE_URL=http://192.168.0.10:8080
VITE_API_BASE_URL=

# Optional: set this if Vite dev/preview server should proxy /api to a remote backend.
# Example: VITE_API_PROXY_TARGET=http://192.168.0.10:8080
VITE_API_PROXY_TARGET=
