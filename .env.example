# Copy to .env for local Docker Compose runs.

COMPOSE_PROJECT_NAME=warehouse-dashboard
TZ=Asia/Seoul

# DB/schema.sql currently creates and uses warehouse_db.
MYSQL_DATABASE=warehouse_db
MYSQL_USER=warehouse_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PORT=3307

BACKEND_PORT=8080
FRONTEND_PORT=5173

AUTH_TOKEN_TTL_HOURS=168
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.*.*:*,http://10.*.*.*:*,http://172.*.*.*

# Empty means the production nginx frontend proxies /api to the backend container.
VITE_API_BASE_URL=
